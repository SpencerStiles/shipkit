# =============================================================================
# ShipKit — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these in your Vercel dashboard for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL — use Neon or Supabase for production)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/shipkit?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: your production URL (e.g. https://shipkit-pi.vercel.app)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://shipkit-pi.vercel.app"

# -----------------------------------------------------------------------------
# GitHub OAuth
# Create at: https://github.com/settings/developers -> OAuth Apps -> New
# Homepage URL: https://shipkit-pi.vercel.app
# Authorization callback URL: https://shipkit-pi.vercel.app/api/auth/callback/github
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# -----------------------------------------------------------------------------
# Google OAuth
# Create at: https://console.cloud.google.com -> APIs -> Credentials -> OAuth 2.0
# Authorized redirect URI: https://shipkit-pi.vercel.app/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# OpenAI
# Get at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# Stripe
# Get secret key at: https://dashboard.stripe.com/apikeys
# Production webhook URL to register: https://shipkit-pi.vercel.app/api/webhooks/stripe
# Get webhook secret after registering the webhook in Stripe dashboard
# Create price IDs at: https://dashboard.stripe.com/products
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# -----------------------------------------------------------------------------
# Email (optional - Resend for transactional emails)
# Get at: https://resend.com/api-keys
# If not set, emails are logged to console in dev and skipped in production.
# See src/lib/email.ts for integration instructions.
# -----------------------------------------------------------------------------
# RESEND_API_KEY="re_..."
